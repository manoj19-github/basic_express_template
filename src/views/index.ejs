<!DOCTYPE html>
<html>

<head>
	<title>
		<%= title %>
	</title>
	<style>
		body {
			font-family: sans-serif;
			padding: 20px;
			background-color: #121212;
			color: #fff;
		}

		#log {
			background: #000;
			padding: 10px;
			height: 300px;
			overflow-y: scroll;
			border: 1px solid #333;

		}

		.status-on {
			color: #00ff00;
		}

		.status-off {
			color: #ff0000;
		}
	</style>
</head>

<body>
	<h1>WebSocket Test</h1>

	<p id="status" class="status-off">Connecting ....</p>
	<form id="message-form">
		<input type="text" id="message-input" placeholder="send cargo..." required />
		<button type="submit">Deploy Message</button>
		<h1>Live Stream Logs:</h1>
		<pre id="log"></pre>
	</form>


	<script>
		const statusEl = document.getElementById("status");
		const logEl = document.getElementById("log");
		const messageForm = document.getElementById("message-form");
		const messageInput = document.getElementById("message-input");
		const socket = new WebSocket("ws://localhost:5000");



		socket.onmessage = (event) => {
			const li = document.createElement("li");
			li.textContent = event.data;
			console.log('event.data;: ', event.data);
			document.getElementById("messages").appendChild(li);
		};

		const appendLog = (label, message) => {
			const entry = `${new Date().toLocaleString()} :  ${label}: ${message}`;
			logEl.innerHTML += entry + "<br>";
			logEl.scrollTop = logEl.scrollHeight;
		};

		function sendMessage() {
			const input = document.getElementById("msg");
			socket.send(input.value);
			input.value = "";
		}

		socket.addEventListener("open", () => {
			statusEl.style.color = "#00ff00";
			statusEl.textContent = "Connected";
			appendLog("[SYSTEM]", "Tunnel Established");
		});
		socket.addEventListener("close", () => {
			statusEl.style.color = "#ff0000";
			statusEl.textContent = "Disconnected";
			appendLog("[SYSTEM]", "Tunnel Collapsed");
		});
		socket.addEventListener("message", (event) => {
			appendLog("[RECEIVED]", event.data);
		});
		messageForm.addEventListener("submit", (event) => {
			event.preventDefault();
			if (socket.readyState !== WebSocket.OPEN) {
				appendLog("[ERROR]", event.data);
			} else {
				const message = messageInput.value.trim();
				socket.send(message);
				appendLog("[SENT]", message);
				messageInput.value = "";
			}
		});

	</script>
</body>

</html>